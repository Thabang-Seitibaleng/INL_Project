<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Architect | Login</title>
    <link rel="stylesheet" href="/style.css" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      /* ── Auth Page Layout ───────────────────────────────────────────────── */
      .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--bg-main, #f9fafb);
        padding: 24px;
      }

      .auth-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        padding: 48px 40px;
        width: 100%;
        max-width: 420px;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      }

      .auth-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 32px;
      }

      .auth-logo-icon {
        width: 36px;
        height: 36px;
        background: #111827;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 800;
        font-size: 16px;
      }

      .auth-logo-text {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        letter-spacing: -0.3px;
      }

      .auth-heading {
        font-size: 24px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 6px;
        letter-spacing: -0.4px;
      }

      .auth-subheading {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 32px;
      }

      .auth-subheading a {
        color: #111827;
        font-weight: 600;
        text-decoration: none;
      }

      .auth-subheading a:hover {
        text-decoration: underline;
      }

      /* ── Form Fields ────────────────────────────────────────────────────── */
      .auth-field {
        margin-bottom: 16px;
      }

      .auth-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 6px;
      }

      .auth-input {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        font-size: 14px;
        color: #111827;
        background: #ffffff;
        transition: border-color 0.15s, box-shadow 0.15s;
        box-sizing: border-box;
        font-family: "Inter", sans-serif;
      }

      .auth-input:focus {
        outline: none;
        border-color: #111827;
        box-shadow: 0 0 0 3px rgba(17, 24, 39, 0.08);
      }

      .auth-input::placeholder {
        color: #9ca3af;
      }

      /* ── Error Banner ───────────────────────────────────────────────────── */
      .auth-error {
        background: #fef2f2;
        border: 1px solid #fecaca;
        border-radius: 8px;
        padding: 12px 14px;
        font-size: 13px;
        color: #dc2626;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* ── OTP Field (hidden until 2FA triggered) ─────────────────────────── */
      .otp-section {
        display: none;
        margin-bottom: 16px;
      }

      .otp-section.visible {
        display: block;
      }

      .otp-hint {
        font-size: 12px;
        color: #6b7280;
        margin-top: 6px;
      }

      /* ── Submit Button ──────────────────────────────────────────────────── */
      .auth-btn {
        width: 100%;
        padding: 12px;
        background: #111827;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.15s, transform 0.1s;
        font-family: "Inter", sans-serif;
        margin-top: 8px;
      }

      .auth-btn:hover   { background: #1f2937; }
      .auth-btn:active  { transform: scale(0.99); }
      .auth-btn:disabled {
        background: #9ca3af;
        cursor: not-allowed;
      }

      /* ── Divider ────────────────────────────────────────────────────────── */
      .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 24px 0;
        color: #9ca3af;
        font-size: 12px;
      }

      .auth-divider::before,
      .auth-divider::after {
        content: "";
        flex: 1;
        height: 1px;
        background: #e5e7eb;
      }

      /* ── Footer note ────────────────────────────────────────────────────── */
      .auth-footer {
        margin-top: 24px;
        text-align: center;
        font-size: 13px;
        color: #6b7280;
      }

      .auth-footer a {
        color: #111827;
        font-weight: 600;
        text-decoration: none;
      }

      .auth-footer a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <div class="auth-wrapper">
      <div class="auth-card">

        <!-- Logo -->
        <div class="auth-logo">
          <div class="auth-logo-icon">BAW</div>
          <span class="auth-logo-text">Budget and Wealth</span>
        </div>

        <h1 class="auth-heading">Welcome back</h1>
        <p class="auth-subheading">Sign in to your wealth dashboard</p>

        <!-- Error banner (shown if server sends ?error=...) -->
        <% if (typeof error !== 'undefined' && error) { %>
          <div class="auth-error">
            ⚠️ <%= error %>
          </div>
        <% } %>

        <!-- Login Form -->
        <form method="POST" action="/auth/login" id="loginForm">

          <div class="auth-field">
            <label class="auth-label" for="email">Email address</label>
            <input
              type="email"
              id="email"
              name="email"
              class="auth-input"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>

          <div class="auth-field">
            <label class="auth-label" for="password">Password</label>
            <input
              type="password"
              id="password"
              name="password"
              class="auth-input"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            />
          </div>

          <!-- OTP field — hidden until 2FA is required -->
          <div class="otp-section" id="otpSection">
            <label class="auth-label" for="otp">One-Time Password</label>
            <input
              type="text"
              id="otp"
              name="otp"
              class="auth-input"
              placeholder="6-digit code"
              maxlength="6"
              autocomplete="one-time-code"
            />
            <p class="otp-hint">Check your phone or email for the OTP code.</p>
          </div>

          <button type="submit" class="auth-btn" id="submitBtn">
            Sign in
          </button>
        </form>

        <div class="auth-divider">or</div>

        <div class="auth-footer">
          Don't have an account? <a href="/register">Create one</a>
        </div>

      </div>
    </div>

    <script>
      // Show OTP field if redirected back with ?requires2FA=true
      const params = new URLSearchParams(window.location.search);
      if (params.get("requires2FA") === "true") {
        document.getElementById("otpSection").classList.add("visible");
        document.getElementById("submitBtn").textContent = "Verify OTP";
      }

      // Basic loading state on submit
      document.getElementById("loginForm").addEventListener("submit", function () {
        const btn = document.getElementById("submitBtn");
        btn.disabled = true;
        btn.textContent = "Signing in...";
      });
    </script>
  </body>
</html>
