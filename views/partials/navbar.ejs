<header class="top-navbar">
  <div class="logo-area">
    <h1>Architect</h1>
  </div>

  <nav class="main-nav">
    <a href="/" class="nav-link">Dashboard</a>
    <a href="/cashflow" class="nav-link active">Cashflow</a>
    <a href="/portfolio" class="nav-link">Portfolio</a>
    <a href="/forecaster" class="nav-link">Forecaster</a>
    <a href="/atlas" class="nav-link">Atlas</a>
  </nav>

  <div class="header-actions">
    <button class="icon-btn">🔔</button>
    <button class="icon-btn">⚙️</button>
    <button class="icon-btn" id="theme-toggle" onclick="toggleTheme()">
      🌙
    </button>
    <img
      src="https://ui-avatars.com/api/?name=Marcus+Sterling&background=random"
      alt="User"
      class="nav-profile-img"
    />
  </div>
</header>

<!--This script will change the active nav link based on the current URL path.-->
<script>
  document.addEventListener("DOMContentLoaded", () => {
    const currentPath = window.location.pathname;
    const navLinks = document.querySelectorAll(".nav-link");

    navLinks.forEach((link) => {
      if (link.getAttribute("href") === currentPath) {
        link.classList.add("active");
      } else {
        link.classList.remove("active");
      }
    });
  });
</script>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toggleGroups = document.querySelectorAll(".toggle-pill");

    toggleGroups.forEach((group) => {
      const buttons = group.querySelectorAll(".pill-btn");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          buttons.forEach((btn) => btn.classList.remove("active"));
          button.classList.add("active");
        });
      });
    });
  });
</script>
